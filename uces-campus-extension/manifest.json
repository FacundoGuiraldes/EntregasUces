{
  "manifest_version": 3,
  "name": "UCES Importador de Actividades",
  "version": "1.0.1",
  "description": "Extrae las próximas actividades desde Campus UCES y las carga en la app Entregas UCES.",
  "permissions": ["activeTab", "tabs", "storage", "scripting"],
  "host_permissions": [
    "https://*.uces.edu.ar/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://facundoguiraldes.github.io/*",
    "file:///*"
  ],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "UCES Importador",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://*.uces.edu.ar/*"],
      "js": ["content-campus.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://localhost/*",
        "http://127.0.0.1/*",
        "https://facundoguiraldes.github.io/*",
        "file:///*"
      ],
      "js": ["content-app.js"],
      "run_at": "document_idle"
    }
  ]
}
